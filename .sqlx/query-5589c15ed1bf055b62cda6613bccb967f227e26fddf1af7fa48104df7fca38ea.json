  "query": "\n            SELECT r.id, r.source_id, r.provider_id, rm.created_at\n            FROM role_membership rm\n            JOIN \"role\" r ON r.id = rm.member_role_id\n            WHERE rm.parent_role_id = $1\n            ORDER BY rm.member_role_id\n            ",
